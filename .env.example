# ============================================================================
# SEZ API – konfigurace
# Zkopírujte tento soubor jako .env a doplňte hodnoty.
# ============================================================================

# ---------- Povinné ----------

# Client ID registrovaný v JSU (formát: IČO_Název)
SEZ_CLIENT_ID=25488627_KrajskaZdravotniVerejnyTest

# Cesta k certifikátu EZCA II (.pfx / .p12)
SEZ_P12_PATH=/cesta/ke/certifikatu.pfx

# Heslo k certifikátu
SEZ_P12_PASSWORD=tajne-heslo

# ---------- Volitelné ----------

# UID certifikátu z EZCA (kid claim v JWT). Pokud není zadáno, použije se
# SubjectKeyIdentifier z certifikátu.
SEZ_CERT_UID=

# URL API Gateway (výchozí: T2 testovací prostředí)
# T2:  https://gwy-ext-sec-t2.csez.cz
# Prod: https://gwy-ext-sec.csez.cz
SEZ_GATEWAY=https://gwy-ext-sec-t2.csez.cz

# Host a port webového rozhraní
SEZ_HOST=0.0.0.0
SEZ_PORT=8000

# ---------- Produkce (volitelné) ----------
# Heslo pro přepnutí na produkci v webovém rozhraní
# SEZ_PROD_PASSWORD=

# Certifikát a přístupy pro produkční prostředí
# SEZ_PROD_CLIENT_ID=
# SEZ_PROD_P12_PATH=
# SEZ_PROD_P12_PASSWORD=
# SEZ_PROD_CERT_UID=
